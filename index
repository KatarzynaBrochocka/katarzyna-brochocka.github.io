/* --- MECHANIZM ZMIANY JĘZYKA --- */
        body[data-lang="pl"] .lang-en { display: none !important; }
        body[data-lang="en"] .lang-pl { display: none !important; }

        /* --- SEKCJA STARTOWA (HERO) --- */
