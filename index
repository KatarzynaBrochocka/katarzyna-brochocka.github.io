<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Katarzyna Brochocka | Composer & Pianist</title>
    <style>
        /* --- GŁÓWNE STYLE STRONY --- */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Georgia', serif;
            background-color: #f9f9f6;
            color: #1a1a1a;
            line-height: 1.6;
            padding: 40px 20px;
        }

        .container {
            max-width: 850px;
            margin: 0 auto;
        }

        /* --- NAGŁÓWEK I PRZYCISKI --- */
        header {
            border-bottom: 1px solid #1a1a1a;
            padding-bottom: 20px;
            margin-bottom: 40px;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            flex-wrap: wrap;
            gap: 20px;
        }

        h1 {
            font-size: 28px;
            font-weight: normal;
            letter-spacing: 3px;
            text-transform: uppercase;
        }

        .subtitle {
            font-family: sans-serif;
            font-size: 12px;
            letter-spacing: 3px;
            color: #666;
            text-transform: uppercase;
            margin-top: 5px;
        }

        .lang-switch {
            font-family: sans-serif;
            font-size: 12px;
            letter-spacing: 2px;
        }

        .lang-switch button {
            background: transparent;
            border: none;
            color: #888;
            cursor: pointer;
            padding: 5px 10px;
            text-transform: uppercase;
            font-weight: normal;
            transition: color 0.3s;
        }

        .lang-switch button:hover {
            color: #1a1a1a;
        }

        .lang-switch button.active {
            font-weight: bold;
            color: #1a1a1a;
            border-bottom: 1px solid #1a1a1a;
        }

        /* --- ZDJĘCIE PROFILOWE --- */
        /* Optymalny rozmiar do wyświetlania to kwadrat ok. 250px lub 300px */
        .profile-container {
            text-align: center;
            margin-bottom: 40px;
        }

        .profile-photo {
            width: 250px;
            height: 250px;
            border-radius: 50%;
            object-fit: cover;
            border: 1px solid #1a1a1a;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }

        /* --- BIOGRAM I SEKCJE --- */
        h2 {
            font-size: 20px;
            font-weight: normal;
            letter-spacing: 2px;
            text-transform: uppercase;
            margin: 40px 0 20px 0;
            border-bottom: 1px dotted #ccc;
            padding-bottom: 5px;
        }

        .bio-box {
            margin-bottom: 25px;
        }

        /* --- SYSTEM ZAKŁADEK DLA BIOGRAMU --- */
        .tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 15px;
        }

        .tab-btn {
            font-family: sans-serif;
            font-size: 11px;
            letter-spacing: 1px;
            background: #eee;
            border: 1px solid #ccc;
            padding: 6px 12px;
            cursor: pointer;
            text-transform: uppercase;
        }

        .tab-btn.active {
            background: #1a1a1a;
            color: #fff;
            border-color: #1a1a1a;
        }

        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: block;
        }

        /* --- LISTA KOMPOZYCJI I WYDAWCY --- */
        ul {
            padding-left: 20px;
            margin-bottom: 20px;
        }

        li {
            margin-bottom: 10px;
        }

        a {
            color: #1a1a1a;
            text-decoration: underline;
        }

        a:hover {
            color: #666;
        }

        .publishers {
            margin: 30px 0;
            padding: 15px;
            background: #fdfdfb;
            border: 1px solid #eee;
        }

        /* --- SIATKA MULTIMEDIÓW (6 OKIENEK) --- */
        .media-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }

        .media-box {
            background: #eaeaea;
            border: 1px solid #ddd;
            aspect-ratio: 16/9;
            overflow: hidden;
        }

        .media-box iframe, .media-box video {
            width: 100%;
            height: 100%;
            border: none;
        }

        /* --- FORMULARZ KONTAKTOWY --- */
        form {
            display: flex;
            flex-direction: column;
            gap: 15px;
            margin-top: 20px;
            background: #fdfdfb;
            padding: 20px;
            border: 1px solid #eee;
        }

        label {
            font-family: sans-serif;
            font-size: 12px;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        input, textarea {
            font-family: 'Georgia', serif;
            padding: 10px;
            border: 1px solid #ccc;
            background: #fff;
            font-size: 14px;
            width: 100%;
        }

        form button {
            font-family: sans-serif;
            background: #1a1a1a;
            color: white;
            border: none;
            padding: 12px;
            cursor: pointer;
            letter-spacing: 2px;
            text-transform: uppercase;
            font-size: 12px;
            transition: background 0.3s;
        }

        form button:hover {
            background: #444;
        }

        /* --- PODSTAWA DZIAŁANIA JĘZYKÓW --- */
        .lang-en { display: none; }
    </style>
</head>
<body>

<div class="container">
    
    <!-- NAGŁÓWEK STRONY -->
    <header>
        <div>
            <h1>Katarzyna Brochocka</h1>
            <div class="subtitle lang-pl">Kompozytorka & Pianistka</div>
            <div class="subtitle lang-en">Composer & Pianist</div>
        </div>
        
        <!-- NAPRAWIONE PRZYCISKI JĘZYKOWE -->
        <div class="lang-switch">
            <button id="pl-btn" class="active" onclick="switchLanguage('pl')">PL</button>
            <button id="en-btn" onclick="switchLanguage('en')">EN</button>
        </div>
    </header>

    <!-- ZDJĘCIE PROFILOWE -->
    <div class="profile-container">
        <!-- Zmień "katarzyna.jpg" na poprawną nazwę swojego pliku ze zdjęciem wrzuconego na GitHub -->
        <img src="katarzyna.jpg" alt="Katarzyna Brochocka" class="profile-photo">
    </div>

    <!-- BIOGRAM (ZAKŁADKI KRÓTKI / DŁUGI) -->
    <h2>
        <span class="lang-pl">Biogram</span>
        <span class="lang-en">Biography</span>
    </h2>
    
    <div class="tabs">
        <button id="tab-short-btn" class="tab-btn active" onclick="openTab('short')">
            <span class="lang-pl">Krótki</span><span class="lang-en">Short</span>
        </button>
        <button id="tab-long-btn" class="tab-btn" onclick="openTab('long')">
            <span class="lang-pl">Długi</span><span class="lang-en">Long</span>
        </button>
    </div>

    <div class="bio-box">
        <div id="short" class="tab-content active">
            <p class="lang-pl">Katarzyna Brochocka to polska kompozytorka i pianistka... (Tutaj wpisz swój krótki biogram po polsku).</p>
            <p class="lang-en">Katarzyna Brochocka is a Polish composer and pianist... (Enter your short bio in English here).</p>
        </div>

        <div id="long" class="tab-content">
            <p class="lang-pl">Tutaj wklej pełny, szczegółowy oraz długi biogram w języku polskim, opisujący całą Twoją karierę i osiągnięcia muzyczne.</p>
            <p class="lang-en">Enter your detailed long biography in English here, describing your entire artistic career and achievements.</p>
        </div>
    </div>

    <!-- KOMPOZYCJE MUZYCZNE -->
    <h2>
        <span class="lang-pl">Kompozycje</span>
        <span class="lang-en">Compositions</span>
    </h2>
    <ul>
        <li>
            <a href="https://link-do-utworu1.com" target="_blank">Tytuł utworu 1 (2025)</a> 
            - <span class="lang-pl">na fortepian i orkiestrę</span><span class="lang-en">for piano and orchestra</span>
        </li>
        <li>
            <a href="https://link-do-utworu2.com" target="_blank">Tytuł utworu 2 (2024)</a> 
            - <span class="lang-pl">utwór kameralny</span><span class="lang-en">chamber work</span>
        </li>
    </ul>

    <!-- ODNOŚNIKI DO WYDAWCÓW -->
    <h2>
        <span class="lang-pl">Wydawcy</span>
        <span class="lang-en">Publishers</span>
    </h2>
    <div class="publishers">
        <p><strong>Universal Edition:</strong> <a href="https://universaledition.com" target="_blank">Zobacz profil kompozytorski</a></p>
        <p style="margin-top: 10px;">
            <strong><span class="lang-pl">Wydawca płyt CD:</span><span class="lang-en">CD Publisher:</span></strong> 
            <a href="https://link-do-wydawcy-plyt.com" target="_blank">Katalog wydań fonograficznych</a>
        </p>
    </div>

    <!-- SZEŚĆ OKIENEK MULTIMEDIALNYCH (AUDIO / VIDEO) -->
    <h2>Multimedia</h2>
    <div class="media-grid">
        <!-- Okienko 1 (Np. YouTube - Podmień ID_FILMU na kod ze swojego linku) -->
        <div class="media-box">
            <iframe src="https://youtube.com" allowfullscreen></iframe>
        </div>
        <!-- Okienko 2 (YouTube) -->
        <div class="media-box">
            <iframe src="https://youtube.com" allowfullscreen></iframe>
        </div>
        <!-- Okienko 3 (Np. Soundcloud - Podmień URL_UTWORU) -->
        <div class="media-box">
            <iframe src="https://soundcloud.com"></iframe>
        </div>
